  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 14px 32px rgba(37, 99, 235, 0.18));
}

._content_15g2e_37 {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

._badge_15g2e_43 {
  align-self: flex-start;
  padding: 6px 14px;
  border-radius: 12px;
  background: rgba(37, 99, 235, 0.12);
  color: #2563eb;
  font-weight: 700;
  letter-spacing: 0.18em;
}

h1 {
  margin: 0;
  font-size: clamp(2rem, 4vw, 2.8rem);
  color: #0f172a;
  line-height: 1.2;
}

p {
  margin: 0;
  color: #475569;
  line-height: 1.7;
}

._actions_15g2e_66 {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
}

._primaryBtn_15g2e_72,
._secondaryBtn_15g2e_73 {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 22px;
  border-radius: 14px;
  text-decoration: none;
  font-weight: 600;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

._primaryBtn_15g2e_72 {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #ffffff;
  box-shadow: 0 18px 36px rgba(37, 99, 235, 0.26);
}
._primaryBtn_15g2e_72:hover {
  transform: translateY(-2px);
  box-shadow: 0 22px 44px rgba(37, 99, 235, 0.28);
}

._secondaryBtn_15g2e_73 {
  background: #ffffff;
  color: #0f172a;
  border: 1px solid rgba(148, 163, 184, 0.4);
  box-shadow: 0 14px 24px rgba(148, 163, 184, 0.12);
}
._secondaryBtn_15g2e_73:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 32px rgba(148, 163, 184, 0.2);
}

