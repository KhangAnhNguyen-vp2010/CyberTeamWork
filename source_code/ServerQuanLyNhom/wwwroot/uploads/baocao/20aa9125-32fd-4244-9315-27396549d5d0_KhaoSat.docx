._wrapper_15g2e_1 {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #e0f2fe, #f3f4f6 65%);
  padding: 32px;
  font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

._card_15g2e_11 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 32px;
  background: #ffffff;
  padding: 40px;
  border-radius: 28px;
  box-shadow: 0 24px 64px rgba(15, 23, 42, 0.15);
  max-width: 960px;
  width: 100%;
  align-items: center;
}

._media_15g2e_24 {
  display: flex;
  justify-content: center;
  align-items: center;
}
._media_15g2e_24 img {
  max-width: 360px;
